{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/franciscomoretti/workgrove/main/schema/workgrove.schema.json",
  "title": "Workgrove configuration",
  "description": "Choose one start mode: either control.start for aggregate orchestration, or per-app start commands. In per-app mode every required TCP app must declare start; Workgrove enforces these cross-field rules at runtime.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "slot", "range", "url", "apps"],
  "properties": {
    "$schema": { "type": "string" },
    "version": { "const": 1 },
    "slot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["env", "default"],
      "properties": {
        "env": { "type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_]*$" },
        "default": { "type": "integer", "minimum": 0 },
        "file": { "type": "string", "minLength": 1 }
      }
    },
    "range": {
      "type": "object",
      "additionalProperties": false,
      "required": ["base", "stride"],
      "properties": {
        "base": { "type": "integer", "minimum": 1024, "maximum": 65535 },
        "stride": { "type": "integer", "minimum": 1, "maximum": 65535 }
      }
    },
    "url": { "type": "string", "minLength": 1 },
    "apps": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": { "pattern": "^[A-Za-z0-9_-]+$" },
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["offset"],
        "properties": {
          "offset": { "type": "integer", "minimum": 0 },
          "exports": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "start": { "$ref": "#/$defs/command" },
          "control": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "label": { "type": "string", "minLength": 1 },
              "open": { "type": "boolean" },
              "probe": { "enum": ["none", "tcp"] },
              "required": { "type": "boolean" }
            }
          }
        }
      }
    },
    "control": {
      "type": "object",
      "additionalProperties": false,
      "not": { "required": ["setup", "postCreate"] },
      "properties": {
        "start": { "$ref": "#/$defs/command" },
        "setup": { "$ref": "#/$defs/command" },
        "postCreate": { "$ref": "#/$defs/command" }
      }
    }
  },
  "$defs": {
    "command": {
      "type": "object",
      "additionalProperties": false,
      "required": ["argv"],
      "properties": {
        "argv": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "cwd": { "type": "string", "minLength": 1 },
        "env": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    }
  }
}
