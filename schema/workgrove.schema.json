{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "number",
      "const": 1
    },
    "stride": {
      "default": 10,
      "type": "integer",
      "minimum": 1,
      "maximum": 65535
    },
    "setup": {
      "type": "object",
      "properties": {
        "argv": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "required": ["argv"],
      "additionalProperties": false
    },
    "start": {
      "type": "object",
      "properties": {
        "argv": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "required": ["argv"],
      "additionalProperties": false
    },
    "apps": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "pattern": "^[A-Za-z0-9_-]+$"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "basePort": {
            "type": "integer",
            "minimum": 1024,
            "maximum": 65535
          }
        },
        "required": ["basePort"],
        "additionalProperties": false
      }
    },
    "env": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "additionalProperties": {
        "type": "string"
      }
    }
  },
  "required": ["version", "stride", "setup", "start", "apps"],
  "additionalProperties": false,
  "$id": "https://raw.githubusercontent.com/franciscomoretti/workgrove/main/schema/workgrove.schema.json",
  "title": "Workgrove configuration",
  "description": "Configure repository commands, worktree port allocation, observable apps, and their exposed environment."
}
