{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "number",
      "const": 1
    },
    "setup": {
      "type": "object",
      "properties": {
        "argv": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "cwd": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": ["argv"],
      "additionalProperties": false
    },
    "appGroups": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "instances": {
            "default": {
              "mode": "per-worktree"
            },
            "oneOf": [
              {
                "type": "object",
                "properties": {
                  "mode": {
                    "type": "string",
                    "const": "per-worktree"
                  }
                },
                "required": ["mode"],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "mode": {
                    "type": "string",
                    "const": "selectable"
                  }
                },
                "required": ["mode"],
                "additionalProperties": false
              }
            ]
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "start": {
            "type": "object",
            "properties": {
              "argv": {
                "minItems": 1,
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "cwd": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": ["argv"],
            "additionalProperties": false
          },
          "stop": {
            "anyOf": [
              {
                "type": "string",
                "const": "process"
              },
              {
                "type": "object",
                "properties": {
                  "argv": {
                    "minItems": 1,
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "cwd": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": ["argv"],
                "additionalProperties": false
              }
            ]
          },
          "env": {
            "type": "object",
            "propertyNames": {
              "type": "string",
              "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
            },
            "additionalProperties": {
              "type": "string"
            }
          },
          "apps": {
            "type": "object",
            "propertyNames": {
              "type": "string",
              "minLength": 1
            },
            "additionalProperties": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "minLength": 1
                },
                "protocol": {
                  "type": "string",
                  "enum": ["http", "tcp"]
                },
                "readiness": {
                  "default": "tcp",
                  "anyOf": [
                    {
                      "type": "string",
                      "const": "tcp"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "path": {
                          "default": "/",
                          "type": "string",
                          "pattern": "^\\/.*"
                        },
                        "statuses": {
                          "default": "200-399",
                          "type": "string",
                          "pattern": "^\\d{3}-\\d{3}$"
                        },
                        "timeoutSeconds": {
                          "default": 60,
                          "type": "integer",
                          "minimum": 1,
                          "maximum": 300
                        },
                        "type": {
                          "type": "string",
                          "const": "http"
                        }
                      },
                      "required": ["type"],
                      "additionalProperties": false
                    }
                  ]
                }
              },
              "required": ["protocol"],
              "additionalProperties": false
            }
          }
        },
        "required": ["start", "stop", "apps"],
        "additionalProperties": false
      }
    }
  },
  "required": ["version", "setup", "appGroups"],
  "additionalProperties": false,
  "$id": "https://raw.githubusercontent.com/franciscomoretti/workgrove/main/schema/workgrove.schema.json",
  "title": "Workgrove configuration",
  "description": "Configure repository commands, dynamic App endpoints, readiness, and exposed App-group environments."
}
