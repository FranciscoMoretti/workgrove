{
  "$schema": "../schema/workgrove.schema.json",
  "version": 2,
  "setup": { "argv": ["bun", "install"] },
  "appGroups": {
    "Product Apps": {
      "slot": { "default": 0, "stride": 10 },
      "start": { "argv": ["bun", "run", "dev:workgrove"] },
      "stop": "process",
      "apps": {
        "Web": { "basePort": 3000 },
        "API": { "basePort": 8000 }
      }
    }
  },
  "env": {
    "WEB_PORT": "{appGroups.Product Apps.apps.Web.port}",
    "API_PORT": "{appGroups.Product Apps.apps.API.port}"
  }
}
