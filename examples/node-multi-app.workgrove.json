{
  "$schema": "../schema/workgrove.schema.json",
  "version": 1,
  "setup": { "argv": ["bun", "install"] },
  "appGroups": {
    "Product Apps": {
      "start": { "argv": ["bun", "run", "dev:workgrove"] },
      "stop": "process",
      "env": {
        "WEB_PORT": "{apps.Web.port}",
        "API_PORT": "{apps.API.port}"
      },
      "apps": {
        "Web": { "protocol": "http", "readiness": "tcp" },
        "API": {
          "protocol": "http",
          "readiness": { "type": "http", "path": "/health" }
        }
      }
    }
  }
}
