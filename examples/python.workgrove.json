{
  "$schema": "../schema/workgrove.schema.json",
  "version": 1,
  "setup": { "argv": ["uv", "sync"] },
  "appGroups": {
    "API": {
      "start": { "argv": ["uv", "run", "python", "-m", "app"] },
      "stop": "process",
      "env": { "PORT": "{apps.API.port}" },
      "apps": {
        "API": {
          "protocol": "http",
          "readiness": { "type": "http", "path": "/health" }
        }
      }
    }
  }
}
