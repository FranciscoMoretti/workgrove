{
  "$schema": "../schema/workgrove.schema.json",
  "version": 1,
  "slot": {
    "env": "WORKGROVE_SLOT",
    "default": 0,
    "file": ".env.worktree.local"
  },
  "ports": { "slotStride": 10 },
  "url": "http://localhost:{port}",
  "apps": {
    "api": {
      "port": { "base": 8000 },
      "control": {
        "label": "API",
        "open": true,
        "probe": "tcp",
        "required": true
      },
      "start": {
        "argv": ["uv", "run", "fastapi", "dev"],
        "env": { "PORT": "{port}" }
      }
    }
  },
  "control": { "setup": { "argv": ["uv", "sync"] } }
}
