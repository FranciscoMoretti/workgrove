{
  "name": "workgrove",
  "version": "0.3.2",
  "description": "Run and manage apps across Git worktrees without terminal juggling.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FranciscoMoretti/workgrove.git"
  },
  "homepage": "https://github.com/FranciscoMoretti/workgrove",
  "bugs": "https://github.com/FranciscoMoretti/workgrove/issues",
  "bin": {
    "workgrove": "scripts/daemon.ts"
  },
  "exports": {
    "./config": "./src/config/public.ts"
  },
  "files": [
    "dist",
    "schema",
    "scripts",
    "src",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "git",
    "worktree",
    "development",
    "ports",
    "dev-server"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "daemon:start": "bun run build && NODE_ENV=production bun scripts/daemon.ts start",
    "daemon:status": "bun scripts/daemon.ts status",
    "daemon:stop": "bun scripts/daemon.ts stop",
    "dev": "bun src/server/server.ts",
    "lint": "bunx ultracite@7.4.3 check",
    "prepack": "bun run build",
    "schema:generate": "bun scripts/generate-config-schema.ts && bunx biome format --write schema/workgrove.schema.json",
    "test": "bun test src/**/*.test.ts",
    "test:pack": "bun scripts/test-packed-artifact.ts",
    "test:types": "tsc --noEmit"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@hookform/resolvers": "^5.4.0",
    "@tanstack/react-query": "^5.80.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "0.553.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.81.0",
    "react-resizable-panels": "^4.12.1",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vite": "^8.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@tailwindcss/vite": "^4.3.2",
    "@types/bun": "latest",
    "@types/node": "^22.8.6",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "tailwindcss": "^4.3.2",
    "typescript": "6.0.2",
    "ultracite": "7.4.3"
  }
}
