{
  "name": "workgrove",
  "version": "0.1.0",
  "description": "Run and manage apps across Git worktrees without terminal juggling.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/franciscomoretti/workgrove.git"
  },
  "homepage": "https://github.com/franciscomoretti/workgrove",
  "bugs": "https://github.com/franciscomoretti/workgrove/issues",
  "bin": {
    "workgrove": "scripts/daemon.ts"
  },
  "exports": {
    "./config": "./src/config/public.ts"
  },
  "files": [
    "dist",
    "schema",
    "scripts",
    "src",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "git",
    "worktree",
    "development",
    "ports",
    "dev-server"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "daemon:start": "bun run build && NODE_ENV=production bun scripts/daemon.ts start",
    "daemon:status": "bun scripts/daemon.ts status",
    "daemon:stop": "bun scripts/daemon.ts stop",
    "dev": "bun src/server/server.ts",
    "lint": "bunx ultracite@7.4.3 check",
    "prepack": "bun run build",
    "test": "bun test src/**/*.test.ts",
    "test:pack": "bun scripts/test-packed-artifact.ts",
    "test:types": "tsc --noEmit"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.7",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-select": "^2.3.3",
    "@tanstack/react-query": "^5.80.3",
    "lucide-react": "0.553.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-resizable-panels": "^3.0.6",
    "vite": "^8.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@types/bun": "latest",
    "@types/node": "^22.8.6",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "typescript": "6.0.2",
    "ultracite": "7.4.3"
  }
}
